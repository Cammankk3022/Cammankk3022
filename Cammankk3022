import hashlib
import os

def calculate_hashes(file_path):
    if not os.path.exists(file_path):
        return None, None
    
    with open(file_path, "rb") as f:  # <-- Huruf A dihapus di sini
        data = f.read()
        md5_hash = hashlib.md5(data).hexdigest()
        sha256_hash = hashlib.sha256(data).hexdigest()
        
    return md5_hash, sha256_hash

def simulate_integrity_check():
    file_name = "test_file.txt"

    # 1. Buat File Asli
    with open(file_name, "w") as f:
        f.write("Ini adalah data asli yang sangat rahasia.")
    
    print(f"--- Simulasi File: {file_name} ---")
    md5_orig, sha256_orig = calculate_hashes(file_name)
    print(f"[ASLI] MD5    : {md5_orig}")
    print(f"[ASLI] SHA-256: {sha256_orig}\n")

    # 2. Modifikasi File (Menambahkan satu titik saja)
    with open(file_name, "a") as f:
        f.write(".")
    
    md5_mod, sha256_mod = calculate_hashes(file_name)
    print(f"[MODIF] MD5   : {md5_mod}")
    print(f"[MODIF] SHA-256: {sha256_mod}\n")

    # 3. Perbandingan
    print("--- Hasil Analisis Integritas ---")
    if md5_orig != md5_mod:
        print("✅ Hash MD5 berubah -> File berbeda / ada perubahan.")
    else:
        print("⚠️ Hash MD5 SAMA -> Kemungkinan ada masalah (seharusnya berubah)")

    if sha256_orig != sha256_mod:
        print("✅ Hash SHA-256 berubah -> File berbeda / ada perubahan.")
    else:
        print("⚠️ Hash SHA-256 SAMA -> Kemungkinan ada masalah (seharusnya berubah)")

    # Tambahan penjelasan untuk bagian ANALISIS di tugas
    print("\n--- PENJELASAN ANALISIS ---")
    print("1. Mengapa MD5 tidak disarankan?")
    print("   - Meski berfungsi di sini, MD5 memiliki kelemahan keamanan: bisa dipalsukan (tabrakan hash), sehingga tidak aman untuk menjamin keaslian data.\n")
    print("2. Keunggulan SHA-256:")
    print("   - Lebih aman, sulit dipalsukan, masih menjadi standar keamanan dunia, dan sangat andal menjamin integritas data.")

if __name__ == "__main__":
    simulate_integrity_check()
